apiVersion: ai.sap.com/v1alpha1
kind: Configuration
metadata:
  name: sample-config
  resourceGroup: default
spec:
  parameters:
    learning_rate: 0.001
    batch_size: 32
    epochs: 10
  inputArtifacts:
    training_data:
      bucket: my-bucket
      path: data/train.csv
  outputArtifacts:
    model:
      bucket: my-bucket
      path: models/model.pkl
